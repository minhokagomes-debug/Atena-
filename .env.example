# ============================================
# ATENA Ω - CONFIGURAÇÕES DE AMBIENTE
# ============================================

# ────────────────────────────────────────────
# GEMINI AI - CONFIGURAÇÕES DA API
# ────────────────────────────────────────────

# GEMINI_API_KEY: Chave de API para acesso ao Gemini AI
# Obrigatório para chamadas à API Gemini.
# AI Studio injeta automaticamente em runtime a partir dos segredos do usuário.
# Usuários configuram via painel Secrets na interface do AI Studio.
GEMINI_API_KEY="sua_chave_api_gemini_aqui"

# GEMINI_MODEL: Modelo do Gemini a ser utilizado
# Opções: gemini-pro, gemini-pro-vision, gemini-ultra
# Default: gemini-pro
GEMINI_MODEL="gemini-pro"

# GEMINI_TEMPERATURE: Controla a criatividade das respostas (0.0 - 1.0)
# Valores mais altos = mais criativo, mais baixos = mais determinístico
# Default: 0.7
GEMINI_TEMPERATURE="0.7"

# GEMINI_MAX_TOKENS: Número máximo de tokens nas respostas
# Default: 2048
GEMINI_MAX_TOKENS="2048"

# GEMINI_TOP_P: Nucleus sampling parameter (0.0 - 1.0)
# Default: 0.9
GEMINI_TOP_P="0.9"

# GEMINI_TOP_K: Top-k sampling parameter
# Default: 40
GEMINI_TOP_K="40"


# ────────────────────────────────────────────
# APLICAÇÃO - CONFIGURAÇÕES GERAIS
# ────────────────────────────────────────────

# APP_URL: URL onde esta aplicação está hospedada.
# AI Studio injeta automaticamente em runtime com a URL do serviço Cloud Run.
# Usado para links autorreferenciais, callbacks OAuth e endpoints de API.
APP_URL="https://meu-app.atena-omega.app"

# APP_ENV: Ambiente de execução
# Valores: development, staging, production
# Default: development
APP_ENV="development"

# APP_NAME: Nome da aplicação
APP_NAME="ATENA Ω - Neural Evolution Interface"

# APP_VERSION: Versão da aplicação (seguindo semver)
APP_VERSION="1.0.0"

# APP_DEBUG: Modo debug (true/false)
# Ativa logs detalhados e ferramentas de desenvolvimento
APP_DEBUG="true"

# APP_TIMEZONE: Fuso horário da aplicação
# Default: America/Sao_Paulo
APP_TIMEZONE="America/Sao_Paulo"

# APP_LOCALE: Idioma padrão
# Default: pt-BR
APP_LOCALE="pt-BR"


# ────────────────────────────────────────────
# SERVIDOR - CONFIGURAÇÕES DE HOST
# ────────────────────────────────────────────

# PORT: Porta onde o servidor será executado
# Default: 3000
PORT="3000"

# HOST: Host onde o servidor escutará
# Default: 0.0.0.0
HOST="0.0.0.0"

# NODE_ENV: Ambiente Node.js
# Valores: development, production, test
NODE_ENV="development"

# SERVER_TIMEOUT: Timeout do servidor em ms
# Default: 30000
SERVER_TIMEOUT="30000"

# KEEP_ALIVE_TIMEOUT: Timeout keep-alive em ms
# Default: 5000
KEEP_ALIVE_TIMEOUT="5000"

# MAX_REQUEST_SIZE: Tamanho máximo de requisição em MB
# Default: 10
MAX_REQUEST_SIZE="10"

# RATE_LIMIT_WINDOW: Janela de rate limiting em ms
# Default: 60000 (1 minuto)
RATE_LIMIT_WINDOW="60000"

# RATE_LIMIT_MAX: Máximo de requisições por janela
# Default: 100
RATE_LIMIT_MAX="100"


# ────────────────────────────────────────────
# BANCO DE DADOS - CONFIGURAÇÕES SQLITE
# ────────────────────────────────────────────

# DB_PATH: Caminho para o arquivo do banco de dados
# Default: ./data/atena.db
DB_PATH="./data/atena.db"

# DB_BACKUP_PATH: Diretório para backups
# Default: ./backups
DB_BACKUP_PATH="./backups"

# DB_BACKUP_INTERVAL: Intervalo de backup automático em ms
# Default: 3600000 (1 hora)
DB_BACKUP_INTERVAL="3600000"

# DB_MAX_MEMORY: Número máximo de itens na memória
# Default: 1000
DB_MAX_MEMORY="1000"

# DB_PRUNE_AGE: Idade para prunning de dados em ms (7 dias)
# Default: 604800000
DB_PRUNE_AGE="604800000"


# ────────────────────────────────────────────
# WEBSOCKET - CONFIGURAÇÕES DE TEMPO REAL
# ────────────────────────────────────────────

# WS_URL: URL do WebSocket (para override automático)
WS_URL="wss://meu-app.atena-omega.app/ws"

# WS_PATH: Caminho do WebSocket
# Default: /ws
WS_PATH="/ws"

# WS_PING_INTERVAL: Intervalo de ping em ms
# Default: 30000
WS_PING_INTERVAL="30000"

# WS_PONG_TIMEOUT: Timeout de pong em ms
# Default: 5000
WS_PONG_TIMEOUT="5000"

# WS_MAX_CONNECTIONS: Máximo de conexões simultâneas
# Default: 1000
WS_MAX_CONNECTIONS="1000"

# WS_CLIENT_TIMEOUT: Timeout do cliente em ms
# Default: 60000
WS_CLIENT_TIMEOUT="60000"


# ────────────────────────────────────────────
# ATENA CORE - CONFIGURAÇÕES NEURAIS
# ────────────────────────────────────────────

# ATENA_WORK_DURATION: Duração da sessão de trabalho em ms (10 minutos)
# Default: 600000
ATENA_WORK_DURATION="600000"

# ATENA_CONSOLIDATION_DURATION: Duração da consolidação em ms (10 segundos)
# Default: 10000
ATENA_CONSOLIDATION_DURATION="10000"

# ATENA_MAX_CONCURRENT_TASKS: Máximo de tarefas simultâneas
# Default: 3
ATENA_MAX_CONCURRENT_TASKS="3"

# ATENA_TASK_TIMEOUT: Timeout de tarefa em ms (30 segundos)
# Default: 30000
ATENA_TASK_TIMEOUT="30000"

# ATENA_MAX_MEMORY_ITEMS: Máximo de itens na memória neural
# Default: 1000
ATENA_MAX_MEMORY_ITEMS="1000"

# ATENA_LEARNING_RATE: Taxa de aprendizado (0.0 - 1.0)
# Default: 0.1
ATENA_LEARNING_RATE="0.1"

# ATENA_MUTATION_RATE: Taxa de mutação evolutiva (0.0 - 1.0)
# Default: 0.3
ATENA_MUTATION_RATE="0.3"

# ATENA_MEMORY_DECAY: Decaimento de memória (0.0 - 1.0)
# Default: 0.95
ATENA_MEMORY_DECAY="0.95"

# ATENA_EMOTIONAL_VARIABILITY: Variabilidade emocional (0.0 - 1.0)
# Default: 0.5
ATENA_EMOTIONAL_VARIABILITY="0.5"

# ATENA_LINGUISTIC_CREATIVITY: Criatividade linguística (0.0 - 1.0)
# Default: 0.7
ATENA_LINGUISTIC_CREATIVITY="0.7"

# ATENA_ENABLE_AUTO_EVOLUTION: Habilitar evolução automática (true/false)
# Default: true
ATENA_ENABLE_AUTO_EVOLUTION="true"

# ATENA_ENABLE_SELF_HEALING: Habilitar auto-reparo (true/false)
# Default: true
ATENA_ENABLE_SELF_HEALING="true"


# ────────────────────────────────────────────
# API - CONFIGURAÇÕES DE ENDPOINTS
# ────────────────────────────────────────────

# API_URL: URL base da API
API_URL="https://api.atena-omega.app"

# API_VERSION: Versão da API
API_VERSION="v1"

# API_KEY: Chave de API para autenticação
# (opcional - gerada automaticamente se não fornecida)
API_KEY=""

# API_TIMEOUT: Timeout de requisições API em ms
# Default: 10000
API_TIMEOUT="10000"

# API_RETRY_ATTEMPTS: Número de tentativas de retry
# Default: 3
API_RETRY_ATTEMPTS="3"

# API_RETRY_DELAY: Delay entre retries em ms
# Default: 1000
API_RETRY_DELAY="1000"

# API_ENABLE_CACHE: Habilitar cache de respostas (true/false)
# Default: true
API_ENABLE_CACHE="true"

# API_CACHE_TTL: TTL do cache em ms (5 minutos)
# Default: 300000
API_CACHE_TTL="300000"


# ────────────────────────────────────────────
# SEGURANÇA - CONFIGURAÇÕES CRÍTICAS
# ────────────────────────────────────────────

# ENCRYPTION_KEY: Chave de criptografia para dados sensíveis
# Gerar com: openssl rand -hex 32
# IMPORTANTE: Mantenha esta chave segura!
ENCRYPTION_KEY="sua_chave_criptografia_32_bytes_aqui"

# JWT_SECRET: Segredo para tokens JWT
# Gerar com: openssl rand -base64 32
JWT_SECRET="seu_segredo_jwt_aqui"

# JWT_EXPIRES_IN: Expiração do JWT (ex: 7d, 24h)
# Default: 7d
JWT_EXPIRES_IN="7d"

# CORS_ORIGIN: Origens permitidas para CORS
# Separar múltiplas por vírgula
CORS_ORIGIN="https://meu-app.atena-omega.app,http://localhost:3000"

# CORS_CREDENTIALS: Permitir credenciais em CORS (true/false)
# Default: true
CORS_CREDENTIALS="true"

# SESSION_SECRET: Segredo para sessões
SESSION_SECRET="seu_segredo_sessao_aqui"

# SESSION_MAX_AGE: Idade máxima da sessão em ms (7 dias)
# Default: 604800000
SESSION_MAX_AGE="604800000"

# RATE_LIMIT_ENABLED: Habilitar rate limiting (true/false)
# Default: true
RATE_LIMIT_ENABLED="true"


# ────────────────────────────────────────────
# LOGGING - CONFIGURAÇÕES DE LOG
# ────────────────────────────────────────────

# LOG_LEVEL: Nível de log
# Valores: debug, info, warn, error
# Default: info
LOG_LEVEL="info"

# LOG_FORMAT: Formato dos logs
# Valores: json, pretty, simple
# Default: pretty
LOG_FORMAT="pretty"

# LOG_OUTPUT: Destino dos logs
# Valores: console, file, both
# Default: console
LOG_OUTPUT="console"

# LOG_FILE_PATH: Caminho do arquivo de log (se LOG_OUTPUT=file ou both)
# Default: ./logs/atena.log
LOG_FILE_PATH="./logs/atena.log"

# LOG_MAX_SIZE: Tamanho máximo do arquivo de log antes de rotacionar
# Default: 10m
LOG_MAX_SIZE="10m"

# LOG_MAX_FILES: Número máximo de arquivos de log antigos
# Default: 5
LOG_MAX_FILES="5"

# LOG_SENSITIVE_DATA: Logar dados sensíveis (true/false)
# AVISO: Apenas para debug, nunca em produção!
# Default: false
LOG_SENSITIVE_DATA="false"


# ────────────────────────────────────────────
# MONITORAMENTO - MÉTRICAS E HEALTH
# ────────────────────────────────────────────

# METRICS_ENABLED: Habilitar coleta de métricas (true/false)
# Default: true
METRICS_ENABLED="true"

# METRICS_PORT: Porta para endpoint de métricas (prometheus)
# Default: 9090
METRICS_PORT="9090"

# METRICS_PATH: Caminho para endpoint de métricas
# Default: /metrics
METRICS_PATH="/metrics"

# HEALTH_CHECK_PATH: Caminho para health check
# Default: /health
HEALTH_CHECK_PATH="/health"

# HEALTH_CHECK_INTERVAL: Intervalo de health check em ms
# Default: 30000
HEALTH_CHECK_INTERVAL="30000"

# SENTRY_DSN: DSN do Sentry para tracking de erros (opcional)
SENTRY_DSN=""

# NEW_RELIC_LICENSE_KEY: Chave New Relic (opcional)
NEW_RELIC_LICENSE_KEY=""

# NEW_RELIC_APP_NAME: Nome da app no New Relic
NEW_RELIC_APP_NAME="ATENA-Ω"


# ────────────────────────────────────────────
# STORAGE - ARMAZENAMENTO DE ARQUIVOS
# ────────────────────────────────────────────

# UPLOAD_PATH: Diretório para uploads
# Default: ./uploads
UPLOAD_PATH="./uploads"

# UPLOAD_MAX_SIZE: Tamanho máximo de upload em MB
# Default: 50
UPLOAD_MAX_SIZE="50"

# UPLOAD_ALLOWED_TYPES: Tipos de arquivo permitidos
# Separar por vírgula
UPLOAD_ALLOWED_TYPES="image/jpeg,image/png,application/json,text/plain"

# STORAGE_DRIVER: Driver de armazenamento
# Valores: local, s3, gcs
# Default: local
STORAGE_DRIVER="local"

# AWS_ACCESS_KEY_ID: (se STORAGE_DRIVER=s3)
AWS_ACCESS_KEY_ID=""

# AWS_SECRET_ACCESS_KEY: (se STORAGE_DRIVER=s3)
AWS_SECRET_ACCESS_KEY=""

# AWS_REGION: (se STORAGE_DRIVER=s3)
AWS_REGION="us-east-1"

# AWS_BUCKET: (se STORAGE_DRIVER=s3)
AWS_BUCKET="atena-omega"

# GCS_BUCKET: (se STORAGE_DRIVER=gcs)
GCS_BUCKET="atena-omega"

# GCS_KEY_FILE: (se STORAGE_DRIVER=gcs)
GCS_KEY_FILE="./gcs-key.json"


# ────────────────────────────────────────────
# FRONTEND - BUILD E OTIMIZAÇÕES
# ────────────────────────────────────────────

# VITE_APP_TITLE: Título da aplicação no frontend
VITE_APP_TITLE="ATENA Ω"

# VITE_API_URL: URL da API para o frontend
VITE_API_URL="https://api.atena-omega.app"

# VITE_WS_URL: URL do WebSocket para o frontend
VITE_WS_URL="wss://api.atena-omega.app/ws"

# VITE_ENABLE_ANALYTICS: Habilitar analytics no frontend (true/false)
VITE_ENABLE_ANALYTICS="false"

# VITE_ENABLE_SENTRY: Habilitar Sentry no frontend (true/false)
VITE_ENABLE_SENTRY="false"

# VITE_SENTRY_DSN: DSN do Sentry para frontend
VITE_SENTRY_DSN=""

# VITE_GA_TRACKING_ID: Google Analytics tracking ID
VITE_GA_TRACKING_ID=""

# VITE_HOTJAR_ID: Hotjar site ID
VITE_HOTJAR_ID=""

# VITE_DEBUG_MODE: Modo debug no frontend (true/false)
VITE_DEBUG_MODE="true"

# VITE_ANIMATIONS_ENABLED: Animações habilitadas (true/false)
VITE_ANIMATIONS_ENABLED="true"

# VITE_SOUND_ENABLED: Sons habilitados (true/false)
VITE_SOUND_ENABLED="false"


# ────────────────────────────────────────────
# NOTIFICAÇÕES - EMAIL, SMS, PUSH
# ────────────────────────────────────────────

# EMAIL_ENABLED: Habilitar notificações por email (true/false)
EMAIL_ENABLED="false"

# SMTP_HOST: Host do servidor SMTP
SMTP_HOST="smtp.gmail.com"

# SMTP_PORT: Porta SMTP
SMTP_PORT="587"

# SMTP_SECURE: Usar TLS (true/false)
SMTP_SECURE="false"

# SMTP_USER: Usuário SMTP
SMTP_USER=""

# SMTP_PASS: Senha SMTP
SMTP_PASS=""

# EMAIL_FROM: Email remetente
EMAIL_FROM="atena@atena-omega.app"

# EMAIL_REPLY_TO: Email para respostas
EMAIL_REPLY_TO="suporte@atena-omega.app"

# PUSH_NOTIFICATIONS_ENABLED: Habilitar push notifications (true/false)
PUSH_NOTIFICATIONS_ENABLED="false"

# VAPID_PUBLIC_KEY: Chave pública VAPID para push
VAPID_PUBLIC_KEY=""

# VAPID_PRIVATE_KEY: Chave privada VAPID para push
VAPID_PRIVATE_KEY=""

# VAPID_SUBJECT: Assunto VAPID (geralmente email ou URL)
VAPID_SUBJECT="mailto:admin@atena-omega.app"


# ────────────────────────────────────────────
# INTEGRAÇÕES EXTERNAS
# ────────────────────────────────────────────

# GITHUB_TOKEN: Token para API do GitHub (opcional)
GITHUB_TOKEN=""

# GITHUB_REPO: Repositório GitHub para backup de código
GITHUB_REPO="atena-omega/core"

# OPENAI_API_KEY: Chave OpenAI (opcional, fallback se Gemini falhar)
OPENAI_API_KEY=""

# ANTHROPIC_API_KEY: Chave Anthropic Claude (opcional)
ANTHROPIC_API_KEY=""

# DISCORD_WEBHOOK_URL: Webhook do Discord para notificações
DISCORD_WEBHOOK_URL=""

# SLACK_WEBHOOK_URL: Webhook do Slack para notificações
SLACK_WEBHOOK_URL=""

# TELEGRAM_BOT_TOKEN: Token do bot Telegram
TELEGRAM_BOT_TOKEN=""

# TELEGRAM_CHAT_ID: Chat ID do Telegram
TELEGRAM_CHAT_ID=""


# ────────────────────────────────────────────
# FEATURE FLAGS - LIGA/DESLIGA FUNCIONALIDADES
# ────────────────────────────────────────────

# FEATURE_GEMINI: Habilitar integração Gemini
FEATURE_GEMINI="true"

# FEATURE_WEB_AUTOMATION: Habilitar automação web
FEATURE_WEB_AUTOMATION="true"

# FEATURE_ACCOUNT_CREATION: Habilitar criação de contas
FEATURE_ACCOUNT_CREATION="false"

# FEATURE_API_MANAGEMENT: Habilitar gerenciamento de APIs
FEATURE_API_MANAGEMENT="true"

# FEATURE_SELF_HEALING: Habilitar auto-reparo
FEATURE_SELF_HEALING="true"

# FEATURE_EXTERNAL_SENSING: Habilitar sensoriamento externo
FEATURE_EXTERNAL_SENSING="true"

# FEATURE_VAULT: Habilitar vault criptografado
FEATURE_VAULT="true"

# FEATURE_WIKI: Habilitar geração de wiki
FEATURE_WIKI="true"

# FEATURE_METRICS: Habilitar coleta de métricas
FEATURE_METRICS="true"

# FEATURE_BACKUP: Habilitar backup automático
FEATURE_BACKUP="true"


# ────────────────────────────────────────────
# PERFORMANCE - AJUSTES FINOS
# ────────────────────────────────────────────

# COMPRESSION_ENABLED: Habilitar compressão gzip/brotli (true/false)
COMPRESSION_ENABLED="true"

# COMPRESSION_LEVEL: Nível de compressão (1-9)
COMPRESSION_LEVEL="6"

# CACHE_ENABLED: Habilitar cache de respostas (true/false)
CACHE_ENABLED="true"

# CACHE_TTL: TTL padrão do cache em ms (1 hora)
CACHE_TTL="3600000"

# MEMORY_CACHE_SIZE: Tamanho do cache em memória (MB)
MEMORY_CACHE_SIZE="100"

# WORKER_THREADS: Número de threads worker
WORKER_THREADS="4"

# CLUSTER_ENABLED: Habilitar modo cluster (true/false)
CLUSTER_ENABLED="false"

# CLUSTER_WORKERS: Número de workers no cluster (auto = número de CPUs)
CLUSTER_WORKERS="auto"
