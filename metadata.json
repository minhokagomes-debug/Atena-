{
  "name": "ATENA Ω - Neural Evolution Interface",
  "short_name": "ATENA Ω",
  "description": "Sistema de evolução contínua com aprendizado profundo, memória contextual e geração autônoma de código. Um organismo digital em evolução perpétua.",
  "theme_color": "#0a0a0f",
  "background_color": "#0a0a0f",
  "display": "standalone",
  "display_override": ["standalone", "fullscreen", "minimal-ui"],
  "orientation": "any",
  "scope": "/",
  "start_url": "/?source=pwa",
  "id": "/?source=pwa",
  "lang": "pt-BR",
  "dir": "ltr",
  "categories": ["productivity", "utilities", "artificial intelligence"],
  "icons": [
    {
      "src": "/icons/icon-72x72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "any"
