    },
    {
      "src": "/icons/maskable-icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/maskable-icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/dashboard.jpg",
      "sizes": "1280x720",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "Dashboard da ATENA Ω mostrando métricas neurais e tarefas ativas"
    },
    {
      "src": "/screenshots/mobile.jpg",
      "sizes": "720x1280",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "Interface móvel da ATENA Ω com chat neural"
    }
  ],
  "shortcuts": [
    {
      "name": "Nova Tarefa",
      "short_name": "Nova",
      "description": "Iniciar nova tarefa neural",
      "url": "/?action=new-task",
      "icons": [
        {
          "src": "/icons/shortcut-new-task.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Chat Neural",
      "short_name": "Chat",
      "description": "Abrir interface de chat",
      "url": "/?action=chat",
      "icons": [
        {
          "src": "/icons/shortcut-chat.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Métricas",
      "short_name": "Stats",
      "description": "Visualizar métricas de evolução",
      "url": "/?action=metrics",
      "icons": [
        {
          "src": "/icons/shortcut-metrics.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://atena-omega.app/manifest.json"
    }
  ],
  "prefer_related_applications": false,
  "scope_extensions": [
    {
      "origin": "https://api.atena-omega.app"
    }
  ],
  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },
  "protocol_handlers": [
    {
      "protocol": "web+atena",
      "url": "/?command=%s"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "file_handlers": {
    "text/plain": {
      "url": "/?file=%s"
    },
    "application/json": {
      "url": "/?json=%s"
    }
  },
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "name",
      "text": "description",
      "url": "link",
      "files": [
        {
          "name": "file",
          "accept": ["text/plain", "application/json"]
        }
      ]
    }
  },
  "note_taking": {
    "new_note_url": "/?action=new-note"
  },
  "splash_pages": null,
  "permissions": {
    "requestFramePermissions": []
  },
  "features": {
    "dark_mode": true,
    "animations": true,
    "sound_enabled": false,
    "notifications_enabled": true
  },
  "version": "1.0.0",
  "version_code": 1,
  "release_date": "2026-03-09",
  "developer": {
    "name": "ATENA Ω Core",
    "url": "https://github.com/atena-omega"
  }
}
